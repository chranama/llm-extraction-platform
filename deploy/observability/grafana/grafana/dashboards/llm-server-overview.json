{
  "id": null,
  "uid": "llm-server-overview",
  "title": "Gateway + Backend Overview",
  "tags": ["llm", "gateway", "observability"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Observed Targets",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "count(up{job=~\"llm-server-api-host|llm_server_container|llm-server-gateway-host\"} == 1)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "timeseries",
      "title": "Gateway Request Rate (req/s)",
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (route, method) (rate(gateway_requests_total{job=~\"llm-server-gateway-host\"}[5m]))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Gateway Latency p95 (s)",
      "id": 3,
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(gateway_request_duration_seconds_bucket{job=~\"llm-server-gateway-host\"}[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Gateway Edge Errors (rate)",
      "id": 4,
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (code) (rate(gateway_edge_errors_total{job=~\"llm-server-gateway-host\"}[5m]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Backend API Request Rate (req/s)",
      "id": 5,
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (route, model_id) (rate(llm_api_request_total{job=~\"llm-server-api-host|llm_server_container\"}[5m]))",
          "legendFormat": "{{route}} [{{model_id}}]",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Backend API Latency p95 (s)",
      "id": 6,
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route, model_id) (rate(llm_api_request_latency_seconds_bucket{job=~\"llm-server-api-host|llm_server_container\"}[5m])))",
          "legendFormat": "{{route}} [{{model_id}}]",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Extraction Request Rate (req/s)",
      "id": 7,
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (schema_id, model_id) (rate(llm_extraction_requests_total{job=~\"llm-server-api-host|llm_server_container\"}[5m]))",
          "legendFormat": "{{schema_id}} [{{model_id}}]",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Validation Failures and Repairs (rate)",
      "id": 8,
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (stage) (rate(llm_extraction_validation_failures_total{job=~\"llm-server-api-host|llm_server_container\"}[5m]))",
          "legendFormat": "validation {{stage}}",
          "refId": "A"
        },
        {
          "expr": "sum by (outcome) (rate(llm_extraction_repair_total{job=~\"llm-server-api-host|llm_server_container\"}[5m]))",
          "legendFormat": "repair {{outcome}}",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    }
  ],
  "templating": {
    "list": []
  }
}
